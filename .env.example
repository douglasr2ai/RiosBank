# Backend
PYTHONUNBUFFERED=1

# Frontend (Vite)
# Deixe vazio em produção (Docker/nginx). O frontend usará paths relativos:
#   - /api -> nginx faz proxy para backend:8000
#   - ws://host atual -> nginx faz upgrade para backend:8000
# Para apontar para um backend externo (dev local sem Docker, p. ex.), preencha:
VITE_API_URL=
VITE_WS_URL=
